# ── База данных ──────────────────────────────────────────
POSTGRES_DB=dostupny_gorod
POSTGRES_USER=dguser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://dguser:CHANGE_ME_STRONG_PASSWORD@db:5432/dostupny_gorod

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Безопасность ─────────────────────────────────────────
SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY_MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Внешние API ──────────────────────────────────────────
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://routing.openstreetmap.de/routed-foot

# ── Приложение ───────────────────────────────────────────
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80
